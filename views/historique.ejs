<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Journal de Traçabilité</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 p-8">

    <div class="max-w-6xl mx-auto bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex justify-between items-center">
            <h1 class="text-xl font-black text-slate-800 uppercase tracking-tight">
                📜 Journal de Traçabilité
            </h1>
            <a href="/" class="text-sm font-bold text-blue-600 hover:underline">← Retour Dashboard</a>
        </div>

        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50/50">
                    <th class="p-5 text-[10px] font-black text-slate-400 uppercase">Utilisateur</th>
                    <th class="p-5 text-[10px] font-black text-slate-400 uppercase">Article</th>
                    <th class="p-5 text-[10px] font-black text-slate-400 uppercase">Action</th>
                    <th class="p-5 text-[10px] font-black text-slate-400 uppercase">Quantité</th>
                    <th class="p-5 text-[10px] font-black text-slate-400 uppercase">Date & Heure</th>
                </tr>
            </thead>
          <tbody class="divide-y divide-slate-100">
    <% if (logs && logs.length > 0) { %>
        <% logs.forEach(log => { %>
        <tr class="hover:bg-blue-50/30 transition-colors">
            <td class="p-5 text-sm">
                <div class="flex flex-col">
                    <span class="font-bold text-slate-800">👤 <%= log.nom_utilisateur %></span>
                    <!-- Affiche le rôle (ex: Administrateur ou le nom associé à id_role) -->
                    <span class="text-[9px] font-black text-blue-500 uppercase"><%= log.nom_role %></span>
                </div>
            </td>
            <td class="p-5 font-bold text-slate-700 underline decoration-slate-200 underline-offset-4">
                <%= log.nom_article %>
            </td>
            <td class="p-5">
                <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase 
                    <%= log.type_action === 'sortie' ? 'bg-orange-100 text-orange-600' : 'bg-green-100 text-green-600' %>">
                    <%= log.type_action %>
                </span>
            </td>
            <td class="p-5 font-black text-slate-800">x<%= log.quantite %></td>
            <td class="p-5 text-xs font-bold text-slate-400">
                <%= new Date(log.date_action).toLocaleString('fr-FR') %>
            </td>
        </tr>
        <% }) %>
    <% } else { %>
        <tr>
            <td colspan="5" class="p-10 text-center text-slate-400 font-medium italic">
                Aucun mouvement enregistré dans le journal.
            </td>
        </tr>
    <% } %>
</tbody>
        </table>
    </div>

</body>
</html>