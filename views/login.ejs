<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Connexion | Agence Event</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen">
    <div class="bg-white p-10 rounded-[40px] shadow-2xl w-full max-w-md border border-white">
        <div class="text-center mb-8">
            <div class="bg-blue-600 w-16 h-16 rounded-2xl mx-auto mb-4 flex items-center justify-center shadow-lg shadow-blue-200">
                <span class="text-white text-3xl font-black">A</span>
            </div>
            <h1 class="text-2xl font-black text-slate-800">Gestion Agence</h1>
            <p class="text-slate-400 text-sm font-bold uppercase tracking-widest mt-1">Accès Sécurisé</p>
        </div>

        <form action="/login" method="POST" class="space-y-4">
            <div>
                <label class="text-[10px] font-black uppercase text-slate-400 ml-4">Email Professionnel</label>
                <input type="email" name="email" required 
                    class="w-full p-4 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-blue-500 focus:bg-white outline-none transition-all font-bold text-slate-700">
            </div>
            <div>
                <label class="text-[10px] font-black uppercase text-slate-400 ml-4">Mot de passe</label>
                <input type="password" name="password" required 
                    class="w-full p-4 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-blue-500 focus:bg-white outline-none transition-all font-bold text-slate-700">
            </div>
            <button type="submit" 
                class="w-full bg-slate-900 hover:bg-blue-600 text-white font-black py-4 rounded-2xl shadow-xl transition-all transform hover:-translate-y-1">
                SE CONNECTER
            </button>
        </form>
    </div>
</body>
</html>