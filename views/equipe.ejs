<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestion des Équipes</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50 min-h-screen py-10 px-4 sm:px-6 lg:px-8">

    <div class="max-w-5xl mx-auto">
        <!-- En-tête -->
        <div class="mb-8 flex items-center justify-between">
            <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Gestion des Équipes</h1>
               <a href="/" class="text-blue-600 hover:underline text-sm font-bold">← Retour au Dashboard</a>
               <!-- Section Ajouter un Rôle -->
<div class="bg-blue-50 rounded-xl border border-blue-100 p-4 mb-6">
    <h4 class="text-xs font-black uppercase text-blue-400 mb-3 tracking-widest">Nouveau Rôle</h4>
    <form action="/admin/ajouter-role" method="POST" class="flex gap-2">
        <input type="text" name="nom_role" placeholder="Ex: Photographe" required
            class="flex-1 px-3 py-2 text-sm border border-blue-200 rounded-lg outline-none focus:ring-2 focus:ring-blue-400">
        <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-bold hover:bg-blue-700 transition-all">
            +
        </button>
    </form>
</div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- Section Formulaire -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 sticky top-6">
                    <h3 class="text-lg font-semibold text-gray-800 mb-6 flex items-center">
                        <i class="fas fa-user-plus mr-2 text-blue-600"></i> Nouveau membre
                    </h3>
                    
                    <form action="/admin/ajouter-membre" method="POST" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Nom complet</label>
                            <input type="text" name="nom" placeholder="Jean Dupont" required
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all outline-none">
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Email professionnel</label>
                            <input type="email" name="email" placeholder="jean@entreprise.fr" required
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all outline-none">
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Mot de passe</label>
                            <input type="password" name="password" placeholder="••••••••" required
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all outline-none">
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Rôle attribué</label>
                            <select name="id_role" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white transition-all outline-none">
                                <% roles.forEach(role => { %>
                                    <option value="<%= role.id %>"><%= role.nom_role %></option>
                                <% }) %>
                            </select>
                        </div>

                        <button type="submit" 
                            class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 rounded-lg transition-colors duration-200 shadow-md">
                            Ajouter au système
                        </button>
                    </form>
                </div>
            </div>

            <!-- Section Tableau -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                        <h3 class="font-bold text-gray-700">Collaborateurs actifs</h3>
                        <span class="text-sm text-gray-500"><%= membres.length %> membres</span>
                    </div>
                    
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="bg-gray-50 text-gray-600 uppercase text-xs font-bold">
                                    <th class="px-6 py-4">Membre</th>
                                    <th class="px-6 py-4">Rôle</th>
                                    <th class="px-6 py-4">Contact</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                <% membres.forEach(m => { %>
                                    <tr class="hover:bg-blue-50/30 transition-colors">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center">
                                                <div class="h-9 w-9 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-sm">
                                                    <%= m.nom.charAt(0) %>
                                                </div>
                                                <div class="ml-3">
                                                    <p class="text-sm font-semibold text-gray-900"><%= m.nom %></p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="px-3 py-1 text-xs font-medium rounded-full 
                                                <%= m.nom_role === 'Admin' ? 'bg-purple-100 text-purple-700' : 'bg-green-100 text-green-700' %>">
                                                <%= m.nom_role %>
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-sm text-gray-600">
                                            <%= m.email %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    
                    <% if (membres.length === 0) { %>
                        <div class="p-10 text-center text-gray-400">
                            <i class="fas fa-users-slash text-4xl mb-3"></i>
                            <p>Aucun membre trouvé dans l'équipe.</p>
                        </div>
                    <% } %>
                </div>
            </div>

        </div>
    </div>

</body>
</html>