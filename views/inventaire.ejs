<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>EventLogix | Inventaire Complet</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-slate-50 p-10" x-data="{ openSection: null }">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="flex justify-between items-center mb-10">
            <div>
                <a href="/" class="text-blue-600 hover:underline text-sm font-bold">← Retour au Dashboard</a>
                <h1 class="text-3xl font-black text-slate-800 mt-2 italic">Gestion de l'Inventaire</h1>
            </div>
            
            <div class="flex items-center gap-4">
                <a href="/historique" class="group flex items-center gap-2 bg-white border-2 border-slate-200 hover:border-blue-500 hover:text-blue-600 px-5 py-2.5 rounded-2xl font-bold text-sm text-slate-600 shadow-sm transition-all active:scale-95">
                    <span class="text-lg group-hover:rotate-12 transition-transform">📜</span>
                    Voir l'Historique
                </a>

                <div class="bg-white px-6 py-3 rounded-2xl shadow-sm border border-slate-200">
                    <span class="text-slate-400 text-xs uppercase font-bold">Total Articles</span>
                    <div class="text-2xl font-black text-blue-600">
                        <% 
                            let total = 0; 
                            Object.values(groupes).forEach(g => total += g.length); 
                        %>
                        <%= total %>
                    </div>
                </div>
            </div>
        </div>

      

        <!-- Section Administration Catégories -->
        <div class="border border-slate-200 rounded-3xl overflow-hidden mb-8 bg-white shadow-sm">
            <button @click="openSection === 'ajout_pres' ? openSection = null : openSection = 'ajout_pres'" 
                    class="w-full flex justify-between items-center p-5 hover:bg-slate-50 transition-colors">
                <span class="font-bold text-slate-700 flex items-center gap-2">
                    <span>🎭</span> Gérer les Types de Prestations
                </span>
                <span class="text-slate-400" x-text="openSection === 'ajout_pres' ? '−' : '+'"></span>
            </button>

            <div x-show="openSection === 'ajout_pres'" x-collapse class="p-5 border-t border-slate-100 bg-slate-50/50">
                <form action="/admin/prestation" method="POST" class="flex gap-3">
                    <input type="text" name="nom_prestation" placeholder="Ex: Vidéo, Sonorisation, Éclairage..." 
                           class="flex-1 border-0 ring-1 ring-slate-200 focus:ring-2 focus:ring-blue-500 p-3 rounded-xl text-sm" required>
                    <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-xl text-xs font-black uppercase tracking-widest hover:bg-blue-700 transition-all">
                        Créer la catégorie
                    </button>
                </form>
            </div>
        </div>
  <!-- BARRE DE RECHERCHE GLOBALE -->
        <div class="mb-8 relative">
            <input type="text" 
                   id="globalSearch"
                   onkeyup="rechercheInventaire()"
                   placeholder="Rechercher un matériel (ex: Nikon, Black Magic, Pied...)" 
                   class="w-full p-5 pl-14 bg-white border-2 border-slate-200 rounded-3xl shadow-sm outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-50/50 transition-all font-bold text-slate-700">
            <span class="absolute left-6 top-5 text-2xl">🔍</span>
        </div>
        <!-- Affichage par Prestation -->
        <div id="inventaireContainer" class="space-y-16">
            <% for (let prestation in groupes) { %>
                <section class="prestation-section">
                    <div class="flex items-center gap-4 mb-6 section-header">
                        <h2 class="text-xl font-black text-slate-800 uppercase tracking-widest italic category-name">
                            <%= prestation %>
                        </h2>
                        <div class="h-px flex-1 bg-gradient-to-r from-slate-300 to-transparent"></div>
                        <span class="bg-slate-800 text-white text-[10px] px-3 py-1.5 rounded-lg font-black tracking-tighter counter-badge">
                            <%= groupes[prestation].length %> ARTICLES
                        </span>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 grid-materiels">
                        <% groupes[prestation].forEach(m => { %>
                            <div class="bg-white rounded-[32px] border border-slate-200 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 group overflow-hidden article-card">
                                <div class="p-7">
                                    <div class="flex justify-between items-start mb-4">
                                        <h3 class="text-lg font-bold text-slate-800 group-hover:text-blue-600 transition-colors leading-tight article-name">
                                            <%= m.nom_article %>
                                        </h3>
                                        <div class="text-right">
                                            <div class="text-2xl font-black text-slate-900 leading-none"><%= m.stock_agence %></div>
                                            <div class="text-[9px] text-slate-400 uppercase font-black tracking-widest mt-1">Dispo</div>
                                        </div>
                                    </div>

                                    <div class="space-y-2 mt-6">
                                        <div class="flex justify-between text-[10px] font-black uppercase tracking-tighter">
                                            <span class="text-slate-400">État du stock</span>
                                            <span class="text-slate-700"><%= m.stock_agence %> / <%= m.stock_total || m.stock_agence %></span>
                                        </div>
                                        <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden">
                                            <% 
                                                let totalMat = m.stock_total || m.stock_agence;
                                                let ratio = (m.stock_agence / totalMat) * 100; 
                                            %>
                                            <div class="h-full <%= ratio < 20 ? 'bg-rose-500' : 'bg-blue-600' %> transition-all duration-700" 
                                                 style="width: <%= ratio %>%"></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="bg-slate-50/80 backdrop-blur-sm p-4 border-t border-slate-100 flex justify-between items-center translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">ID #<%= m.id %></span>
                                    <div class="flex gap-2">
                                        <a href="/admin/edit-materiel/<%= m.id %>" class="p-2 bg-white hover:bg-blue-600 hover:text-white rounded-xl shadow-sm border border-slate-200 transition-all">
                                            <span class="text-xs">✏️</span>
                                        </a>
                                        <a href="/admin/delete-materiel/<%= m.id %>" onclick="return confirm('Supprimer ?')" class="p-2 bg-white hover:bg-rose-600 hover:text-white rounded-xl shadow-sm border border-slate-200 transition-all text-rose-500">
                                            <span class="text-xs">🗑️</span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </section>
            <% } %>
        </div>
    </div>

    <!-- SCRIPT DE RECHERCHE -->
    <script>
        function rechercheInventaire() {
            const input = document.getElementById('globalSearch');
            const filter = input.value.toLowerCase();
            const sections = document.querySelectorAll('.prestation-section');

            sections.forEach(section => {
                const cards = section.querySelectorAll('.article-card');
                let hasVisibleCards = false;

                cards.forEach(card => {
                    const name = card.querySelector('.article-name').textContent.toLowerCase();
                    if (name.includes(filter)) {
                        card.style.display = "";
                        hasVisibleCards = true;
                    } else {
                        card.style.display = "none";
                    }
                });

                // Masquer la section entière (titre + ligne) si aucun article ne correspond
                if (hasVisibleCards) {
                    section.style.display = "";
                } else {
                    section.style.display = "none";
                }
            });
        }
    </script>
</body>
</html>