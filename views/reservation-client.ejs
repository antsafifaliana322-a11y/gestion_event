<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Réserver | Agence Event</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Plus Jakarta Sans', sans-serif; }</style>
</head>
<body class="bg-slate-50 flex items-center justify-center min-h-screen p-4">

    <div class="bg-white p-8 md:p-12 rounded-[2.5rem] shadow-2xl shadow-slate-200 w-full max-w-lg border border-white">
        <!-- Header -->
        <div class="text-center mb-8">
            <div class="bg-red-500 w-16 h-16 rounded-2xl mx-auto mb-4 flex items-center justify-center shadow-lg shadow-red-200 text-white text-2xl">
                📅
            </div>
            <h1 class="text-3xl font-black text-slate-800 tracking-tight">Nouvelle Réservation</h1>
            <p class="text-slate-400 text-sm font-bold uppercase tracking-widest mt-2">Dites-nous tout sur votre projet</p>
        </div>
        
        <form action="/reservation-envoyer" method="POST" class="space-y-6">
            <!-- Nom -->
           <div>
        <label class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-2 tracking-widest">Titre du Projet</label>
        <input type="text" name="titre_evenement" placeholder="Ex: Sortie de promotion" required 
            class="w-full bg-slate-50 border-2 border-transparent p-4 rounded-2xl focus:border-red-500 focus:bg-white outline-none transition-all font-bold text-slate-700">
    </div>

    <!-- NOM DU CLIENT -->
    <div>
        <label class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-2 tracking-widest">Votre email</label>
        <input type="email" name="email_client" placeholder="exemple@mail.mg" required
            class="w-full bg-slate-50 border-2 border-transparent p-4 rounded-2xl focus:border-red-500 focus:bg-white outline-none transition-all font-bold text-slate-700">
    </div>

            <!-- Prestation (La Liste Déroulante) -->
            <div>
                <label class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-2 tracking-widest">Type de Prestation</label>
       <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
    <% prestations.forEach(p => { %>
        <label class="flex items-center p-4 bg-slate-50 rounded-2xl border-2 border-transparent hover:border-red-500 cursor-pointer transition-all group">
            <!-- IMPORTANT: value="<%= p.nom_prestation %>" au lieu de p.id -->
            <input type="checkbox" name="id_prestation[]" value="<%= p.nom_prestation %>" class="w-5 h-5 rounded border-slate-300 text-red-500">
            <span class="ml-3 font-bold text-slate-700 group-hover:text-red-600">
                ✨ <%= p.nom_prestation %>
            </span>
        </label>
    <% }) %>
</div>
            </div>

            <!-- Date et Lieu -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-2 tracking-widest">Date</label>
                    <input type="date" name="date_event" required 
                        class="w-full bg-slate-50 border-2 border-transparent p-4 rounded-2xl focus:border-red-500 focus:bg-white outline-none transition-all font-bold text-slate-700">
                </div>
                <div>
                    <label class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-2 tracking-widest">Lieu</label>
                    <input type="text" name="lieu_event" placeholder="Ex: Antananarivo" required 
                        class="w-full bg-slate-50 border-2 border-transparent p-4 rounded-2xl focus:border-red-500 focus:bg-white outline-none transition-all font-bold text-slate-700">
                </div>
            </div>

            <!-- Bouton Envoyer -->
            <button type="submit" class="w-full bg-slate-900 text-white py-5 rounded-2xl font-black text-sm uppercase tracking-[0.2em] hover:bg-red-500 shadow-xl transition-all transform hover:-translate-y-1 active:scale-95">
                Envoyer la demande
            </button>
            
            <div class="text-center pt-2">
                <a href="/login" class="text-xs font-black text-slate-300 hover:text-blue-500 uppercase tracking-widest transition-colors">
                    ← Retour à la connexion
                </a>
            </div>
        </form>
    </div>

</body>
</html>